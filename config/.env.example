# DevServer v2 — environment configuration template
#
# Copy this file to the project root as `.env` and fill in your own values:
#
#     cp config/.env.example .env
#
# Do NOT commit `.env` — it is gitignored. This template file is the only
# env file that should ever be tracked.

# ─── Paths ───────────────────────────────────────────────
# Absolute path to this repo on your machine. All other paths derive from it.
DEVSERVER_ROOT=/path/to/devserver
WORKTREE_DIR=${DEVSERVER_ROOT}/worktrees
LOG_DIR=${DEVSERVER_ROOT}/logs/tasks

# ─── PostgreSQL ──────────────────────────────────────────
# Required. The web and worker services both read these.
# Change the password before starting the stack — do NOT keep "changeme" in
# anything facing a real network.
DATABASE_URL=postgresql://devserver:changeme@127.0.0.1:5432/devserver
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=devserver
PGPASSWORD=changeme
PGDATABASE=devserver

# ─── Git ─────────────────────────────────────────────────
# Set to true only if your Gitea uses a self-signed cert or an IP-based URL
# with a cert mismatch. Leave false in production.
GIT_SSL_NO_VERIFY=false
# Identity used for every commit the agent makes. Must be quoted if it
# contains a space — bash source-parses this file in a few of the scripts.
GIT_USER_EMAIL=devserver@example.com
GIT_USER_NAME="DevServer Agent"

# ─── Gitea ───────────────────────────────────────────────
# DevServer currently targets Gitea for PR creation. Point this at your
# self-hosted Gitea (or Forgejo) instance.
GITEA_URL=https://your-gitea.example.com
GITEA_OWNER=your-org
GITEA_TOKEN=replace-with-a-gitea-personal-access-token

# ─── Telegram ────────────────────────────────────────────
# Optional but strongly recommended — the worker posts real-time task
# updates (start / success / failure / budget_warning / plan_pending) here.
# Create a bot via @BotFather; CHAT_ID is your own user id (message @userinfobot).
TELEGRAM_BOT_TOKEN=replace-with-a-telegram-bot-token
TELEGRAM_CHAT_ID=replace-with-your-numeric-chat-id

# ─── Telegram Controller ────────────────────────────────
# "local"    = worker calls Bot API directly (simple, works for solo / small teams)
# "external" = worker forwards sends to a separate TelegramController HTTP service
# Leave this as "local" unless you already run the external controller elsewhere.
TELEGRAM_CONTROLLER_MODE=local
TELEGRAM_CONTROLLER_URL=http://127.0.0.1:8200
TELEGRAM_CONTROLLER_TOKEN=

# ─── Claude / Anthropic ─────────────────────────────────
# Two ways to power the Claude Code CLI:
#   1. API key — set ANTHROPIC_API_KEY below and run tasks with claude_mode='api'.
#   2. Max subscription — leave the key empty and run tasks with claude_mode='max';
#      the CLI uses the OAuth session from `claude login` on the host machine.
ANTHROPIC_API_KEY=sk-ant-api03-replace-with-your-key
CLAUDE_BIN=claude
CLAUDE_MAX_TIMEOUT=3600
CLAUDE_ACTIVITY_TIMEOUT=300

# ─── Web UI ──────────────────────────────────────────────
# Public URLs the browser uses to reach the dashboard. Update if you put
# DevServer behind a reverse proxy or expose it on a non-default host.
NEXT_PUBLIC_WS_URL=ws://localhost:3000/api/ws
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ─── Worker ──────────────────────────────────────────────
WORKER_HOST=0.0.0.0
WORKER_PORT=8000
# Maximum number of tasks the PgQueuer consumer will run in parallel.
WORKER_CONCURRENCY=2
# Docker only: override so the web container reaches the worker by its
# service name instead of localhost.
# WORKER_URL=http://worker:8000
