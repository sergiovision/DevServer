# DevServer v2 — environment configuration template
#
# Copy this file to the project root as `.env` and fill in your own values:
#
#     cp config/.env.example .env
#
# Do NOT commit `.env` — it is gitignored. This template file is the only
# env file that should ever be tracked.

# ─── Paths ───────────────────────────────────────────────
# Absolute path to this repo on your machine. All other paths derive from it.
DEVSERVER_ROOT=/path/to/devserver
WORKTREE_DIR=${DEVSERVER_ROOT}/worktrees
LOG_DIR=${DEVSERVER_ROOT}/logs/tasks

# ─── PostgreSQL ──────────────────────────────────────────
# Required. The web and worker services both read these.
# Change the password before starting the stack — do NOT keep "changeme" in
# anything facing a real network.
DATABASE_URL=postgresql://devserver:changeme@127.0.0.1:5432/devserver
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=devserver
PGPASSWORD=changeme
PGDATABASE=devserver

# ─── Git ─────────────────────────────────────────────────
# Set to true only if your Gitea uses a self-signed cert or an IP-based URL
# with a cert mismatch. Leave false in production.
GIT_SSL_NO_VERIFY=false
# Identity used for every commit the agent makes. Must be quoted if it
# contains a space — bash source-parses this file in a few of the scripts.
GIT_USER_EMAIL=devserver@example.com
GIT_USER_NAME="DevServer Agent"

# ─── Gitea ───────────────────────────────────────────────
# DevServer currently targets Gitea for PR creation. Point this at your
# self-hosted Gitea (or Forgejo) instance.
GITEA_URL=https://your-gitea.example.com
GITEA_OWNER=your-org
GITEA_TOKEN=replace-with-a-gitea-personal-access-token

# ─── Telegram ────────────────────────────────────────────
# Optional but strongly recommended — the worker posts real-time task
# updates (start / success / failure / budget_warning / plan_pending) here.
# Create a bot via @BotFather; CHAT_ID is your own user id (message @userinfobot).
TELEGRAM_BOT_TOKEN=replace-with-a-telegram-bot-token
TELEGRAM_CHAT_ID=replace-with-your-numeric-chat-id


# ─── Agent backends (primary + fallbacks) ──────────────
# DevServer can drive multiple coding-agent CLIs via the AgentBackend
# abstraction (apps/worker/src/services/agent_backends.py). Only the
# Anthropic backend is production-tested; the others are wired up so
# you can experiment with them as wingmen without a refactor.
#
# Every task carries a per-task "billing mode" that is vendor-agnostic:
#   • API Platform — worker runs the CLI with the vendor's API-key env
#                    var below. Per-token billing against that account.
#   • Max          — worker strips the API-key env var before spawning
#                    the CLI, so the CLI falls back to its own OAuth /
#                    subscription login (Claude Max, ChatGPT Plus via
#                    `codex login`, Google OAuth for Gemini, Qwen OAuth).
#                    Use this if you already pay the vendor a flat
#                    monthly fee and don't want per-token metering.

# ─── Anthropic (primary, Claude Code CLI) ──────────────
# Install: Claude Code CLI (npm i -g @anthropic-ai/claude-code).
# API Platform: set ANTHROPIC_API_KEY below.
# Max:          run `claude login` on the worker host, leave the key empty.
ANTHROPIC_API_KEY=sk-ant-api03-replace-with-your-key
CLAUDE_BIN=claude
CLAUDE_MAX_TIMEOUT=3600
CLAUDE_ACTIVITY_TIMEOUT=300

# ─── OpenAI (fallback — Codex CLI) ─────────────────────
# Install: `npm i -g @openai/codex` or `brew install --cask codex`.
# API Platform: set OPENAI_API_KEY below.
# Max:          run `codex login` (uses ChatGPT Plus OAuth); leave key empty.
OPENAI_API_KEY=
CODEX_BIN=codex

# ─── Google (fallback — Gemini CLI) ────────────────────
# Install: `npm i -g @google/gemini-cli`.
# API Platform: set GEMINI_API_KEY (from https://aistudio.google.com).
# Max:          run `gemini` interactively once (browser OAuth); leave key empty.
GEMINI_API_KEY=
GEMINI_BIN=gemini

# ─── GLM / Zhipu AI (fallback — glm launcher wrapping Claude Code CLI)
#
# GLM-5.1 scores 58.4% on SWE-bench Pro (beats Claude Opus 4.6) and
# costs ~$0.95/1M input tokens — ~8x cheaper than Claude on output.
# The ``glm`` binary is Claude Code CLI redirected to Zhipu's
# Anthropic-compatible API, so it uses the exact same flags, tools,
# JSON output, and session resume as Claude.
#
# ── Install:
#   Prerequisites: Claude Code CLI must be installed first.
#   curl -fsSL https://raw.githubusercontent.com/xqsit94/glm/main/install.sh | bash
#
# ── How to get your API key:
#   1. Go to https://open.bigmodel.cn and click "Register" (注册)
#   2. Sign up with email or phone number (international emails work)
#   3. After login, go to Console → API Keys (控制台 → API密钥)
#   4. Click "Create API Key" (创建API密钥)
#   5. Copy the key (starts with a long alphanumeric string)
#   6. Paste it below as GLM_API_KEY
#   New accounts get free credits — enough for initial testing.
#
# API Platform: set GLM_API_KEY below.
# Max:          run `glm` interactively once to store auth; leave key empty.
GLM_API_KEY=

# ─── PR Preflight ────────────────────────────────────────
# Comma-separated glob patterns for files to skip during PR preflight
# size and secret checks. Useful for test databases, fixtures, etc.
# Example: "*.sqlite,*.sqlite3,test_data/**"
PREFLIGHT_IGNORE_PATTERNS=

# ─── Obsidian ────────────────────────────────────────────
# Absolute path to the Obsidian vault folder where generated plan
# markdown files are saved (named <plan-key>.md).
# Leave empty to disable plan-to-Obsidian export.
OBSIDIAN_FOLDER=

# ─── Web UI ──────────────────────────────────────────────
# Public URLs the browser uses to reach the dashboard. Update if you put
# DevServer behind a reverse proxy or expose it on a non-default host.
NEXT_PUBLIC_WS_URL=ws://localhost:3000/api/ws
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ─── Worker ──────────────────────────────────────────────
WORKER_HOST=0.0.0.0
WORKER_PORT=8000
# Maximum number of tasks the PgQueuer consumer will run in parallel.
WORKER_CONCURRENCY=2
# Docker only: override so the web container reaches the worker by its
# service name instead of localhost.
# WORKER_URL=http://worker:8000
